# === LLM ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# === Auth ===
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === Admin Auth ===
# Change these credentials in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password-in-production

# === Databases ===
# Set USE_MOCK_RAG=true to skip real Qdrant/Neo4j and use in-memory stubs
USE_MOCK_RAG=true

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=openfounder

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=openfounder

# SQLite (user/session storage — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./openfounder.db

# === App ===
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
